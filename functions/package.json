{
  "name": "kansuke-functions",
  "private": true,
  "main": "index.js",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "lint": "eslint .",
    "test": "mocha --exit test/auth_blocking.test.js test/membership.test.js test/invites.test.js",
    "test:rules": "firebase emulators:exec --only firestore --project demo-kansuke \"mocha --exit test/firestore.rules.test.js\"",
    "serve": "firebase emulators:start --only functions",
    "deploy": "firebase deploy --only functions"
  },
  "dependencies": {
    "firebase-admin": "^13.0.2",
    "firebase-functions": "^6.3.2"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^4.0.1",
    "eslint": "^9.30.1",
    "firebase": "^11.10.0",
    "firebase-tools": "^14.9.0",
    "mocha": "^11.7.1"
  }
}
