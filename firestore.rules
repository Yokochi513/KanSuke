rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // NFR-4: users に登録された認証済み家族メンバーだけにアクセスを許可する。
    function isFamily() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // FR-8: 既定カレンダー（わが家）は固定 ID。全家族メンバーを自動的に
    // 含む前提のため、read と「自分を追加する」update だけ特例を設ける。
    function isDefaultCalendar(calendarId) {
      return calendarId == 'default';
    }

    // FR-8: calendarId の指す calendars ドキュメントの memberIds に自分が
    // 含まれているかを判定する。events のクエリは calendarId を実際の
    // where 句として絞り込む前提（クエリ全体の証明可能性のため）。
    function isCalendarMember(calendarId) {
      return isFamily() &&
        request.auth.uid in
          get(/databases/$(database)/documents/calendars/$(calendarId)).data.memberIds;
    }

    // FR-8: 複数カレンダー機能導入前の予定には calendarId が存在しないため、
    // 既定カレンダー（わが家）に属するものとして扱う。
    function eventCalendarId(data) {
      return ('calendarId' in data) ? data.calendarId : 'default';
    }

    match /users/{uid} {
      allow read: if isFamily();
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    match /calendars/{calendarId} {
      allow read: if isFamily() &&
        (isDefaultCalendar(calendarId) || request.auth.uid in resource.data.memberIds);

      allow create: if isFamily() && request.auth.uid in request.resource.data.memberIds;

      allow update: if isFamily() && (
        isDefaultCalendar(calendarId)
          ? (
            // 既定カレンダーは「参加（自分を追加）」だけを特別に許可する。
            // 追加専用（既存メンバーを維持）かつ memberIds/updatedAt 以外は
            // 変更不可にし、既存メンバーであっても全員を消したり名前を
            // 書き換えたりできないようにする。
            request.auth.uid in request.resource.data.memberIds &&
            request.resource.data.memberIds.hasAll(resource.data.memberIds) &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberIds', 'updatedAt'])
          )
          : request.auth.uid in resource.data.memberIds
      );
    }

    match /events/{eventId} {
      allow read, update, delete: if isCalendarMember(eventCalendarId(resource.data));
      allow create: if isCalendarMember(eventCalendarId(request.resource.data));
    }

    match /reminders/{reminderId} {
      allow read: if isFamily();
    }

    // FR-7: リリース時に CI (Admin SDK) が書き込む最新バージョン情報。
    // クライアントからの書き込みは許可しない（読み取り専用）。
    match /meta/release {
      allow read: if isFamily();
    }

    match /users/{uid}/devices/{token} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
