rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // NFR-4: サインアップ時に Blocking Function が生成する users/{uid} を
    // 持つ認証済みユーザーだけにアクセスを許可する。
    function isRegistered() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // FR-8: calendarId の指す calendars ドキュメントの memberIds に自分が
    // 含まれているかを判定する。events のクエリは calendarId を実際の
    // where 句として絞り込む前提（クエリ全体の証明可能性のため）。
    function isCalendarMember(calendarId) {
      return isRegistered() &&
        request.auth.uid in
          get(/databases/$(database)/documents/calendars/$(calendarId)).data.memberIds;
    }

    // FR-8: 複数カレンダー機能導入前の予定には calendarId が存在しないため、
    // 旧・既定カレンダー（'default'）に属するものとして扱う（後方互換）。
    function eventCalendarId(data) {
      return ('calendarId' in data) ? data.calendarId : 'default';
    }

    match /users/{uid} {
      allow read: if isRegistered();
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // FR-8: カレンダーは参加者（memberIds）だけが読み書きできる。個人カレンダーは
    // アカウント作成時に Blocking Function が memberIds=[本人] で生成する。
    match /calendars/{calendarId} {
      allow read, update: if isRegistered() && request.auth.uid in resource.data.memberIds;

      allow create: if isRegistered() && request.auth.uid in request.resource.data.memberIds;
    }

    match /events/{eventId} {
      allow read, update, delete: if isCalendarMember(eventCalendarId(resource.data));
      allow create: if isCalendarMember(eventCalendarId(request.resource.data));
    }

    match /reminders/{reminderId} {
      allow read: if isRegistered();
    }

    // FR-7: リリース時に CI (Admin SDK) が書き込む最新バージョン情報。
    // クライアントからの書き込みは許可しない（読み取り専用）。
    match /meta/release {
      allow read: if isRegistered();
    }

    match /users/{uid}/devices/{token} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
