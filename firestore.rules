rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // NFR-4: サインアップ時に Blocking Function が生成する users/{uid} を
    // 持つ認証済みユーザーだけにアクセスを許可する。
    function isRegistered() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // FR-8: calendarId の指す calendars ドキュメントの memberIds に自分が
    // 含まれているかを判定する。events のクエリは calendarId を実際の
    // where 句として絞り込む前提（クエリ全体の証明可能性のため）。
    function isCalendarMember(calendarId) {
      return isRegistered() &&
        request.auth.uid in
          get(/databases/$(database)/documents/calendars/$(calendarId)).data.memberIds;
    }

    // Issue #117: 予定ドキュメントの必須フィールドの存在と型を検証する。これが無いと
    // title と deleted だけの不正なドキュメントが書き込めてしまい、クライアントは
    // パースに失敗して表示だけ消える（不正データは DB に残り続ける）。
    //
    // 検証内容は、モデル（lib/models/event.dart の Event.fromMap）が
    // 「フォールバックを持たず必須とするフィールド」に一致させている。こうすると
    // 「Rules が通した予定は必ずモデルでパースできる」「モデルが読めるレガシー予定
    // （旧 ownerId 名・participantIds 欠落・reminderOffsets が旧 number[] 形式）の
    // 更新（ソフト削除など）は拒否しない」の両立になる。
    //
    // create でも update でも request.resource.data は書き込み後の完全な
    // ドキュメントを表すため、同じ関数で両方を検証できる（部分更新のマージ後の
    // 姿を検証するので、既存の正当な予定を不正な形へ上書きすることも防げる）。
    function isWellFormedEvent(data) {
      return data.keys().hasAll([
            'title', 'startAt', 'endAt', 'allDay', 'type', 'memo',
            'updatedBy', 'createdAt', 'updatedAt', 'deleted', 'calendarId'
          ])
        && data.title is string
        && data.startAt is timestamp
        && data.endAt is timestamp
        && data.allDay is bool
        && data.type in ['tentative', 'confirmed']
        && data.memo is string
        && data.updatedBy is string
        && data.createdAt is timestamp
        && data.updatedAt is timestamp
        && data.deleted is bool
        && data.calendarId is string
        // creatorId は必須。旧 ownerId 名のドキュメントも許容する（モデルと同じ後方互換）。
        && ((data.get('creatorId', '') is string && data.get('creatorId', '') != '')
            || (data.get('ownerId', '') is string && data.get('ownerId', '') != ''))
        // participantIds / recurrence 系は導入前のドキュメントには無いため任意。
        // 存在する場合のみ型を検証する（モデルのフォールバックと同じ扱い）。
        && (!('participantIds' in data) || data.participantIds is list)
        && (data.get('recurrenceFrequency', null) == null
            || data.recurrenceFrequency in ['weekly', 'monthly', 'yearly'])
        && (data.get('recurrenceCount', null) == null
            || data.recurrenceCount is number)
        && (data.get('recurrenceUntil', null) == null
            || data.recurrenceUntil is timestamp);
    }

    // FR-8: カレンダーのオーナー（Issue #89）。ownerId のバックフィル
    // （functions/scripts/backfill-calendar-owner-id.js）が済むまでの後方互換として、
    // 欠損時は作成者（creatorId）をオーナーとみなす。
    function calendarOwnerId(data) {
      return ('ownerId' in data) ? data.ownerId : data.creatorId;
    }

    // NFR-4: users は列挙禁止。個別 get のみ許可する（Issue #89）。サインアップは
    // 開放されているため（Issue #87）、列挙を許すと第三者が全ユーザーの名前・メール・
    // 色を取得できてしまう。表示に必要なメンバーは、参加しているカレンダーの
    // memberIds から個別に get する。
    match /users/{uid} {
      allow get: if isRegistered();
      allow list: if false;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // FR-8: カレンダーは参加者（memberIds）だけが読み書きできる。個人カレンダーは
    // アカウント作成時に Blocking Function が memberIds=[本人] / ownerId=本人 で生成する。
    //
    // Issue #89: memberIds / ownerId はクライアントから書き換えられない（メンバーの
    // 追加・削除・退出・オーナー移譲は Callable Function 経由のみ）。カレンダー名の
    // 変更はオーナーだけができる。
    match /calendars/{calendarId} {
      allow read: if isRegistered() && request.auth.uid in resource.data.memberIds;

      allow update: if isRegistered()
        && request.auth.uid in resource.data.memberIds
        && request.resource.data.memberIds == resource.data.memberIds
        && calendarOwnerId(request.resource.data) == calendarOwnerId(resource.data)
        && (request.resource.data.name == resource.data.name
            || request.auth.uid == calendarOwnerId(resource.data));

      allow create: if isRegistered()
        && request.auth.uid in request.resource.data.memberIds
        && request.resource.data.ownerId == request.auth.uid;
    }

    // FR-9: 招待リンク（Issue #90）。トークンのハッシュ・発行者・有効期限などを持つ
    // ため、クライアントからは read も write も一切許可しない。発行・確認・受諾・
    // 取り消し・一覧は Callable Function（`functions/invites.js`、Admin SDK）が
    // 唯一の経路。受諾では memberIds が書き換わるため、この制限が権限モデル
    // （Issue #89）の前提になる。
    match /invites/{inviteId} {
      allow read, write: if false;
    }

    // FR-8: 予定は calendarId 必須（Issue #93）。旧・既定カレンダー（'default'）への
    // フォールバックは、移行スクリプト（functions/scripts/migrate-default-calendar.js）
    // で全予定に calendarId が実在するようになったため廃止した。
    match /events/{eventId} {
      allow read, delete: if isCalendarMember(resource.data.calendarId);
      // Issue #117: 参加者チェックに加え、書き込み後の姿が正しいスキーマである
      // ことを検証する。必須フィールドを欠いた不正なドキュメントを弾く。
      allow update: if isCalendarMember(resource.data.calendarId)
        && isWellFormedEvent(request.resource.data);
      allow create: if isCalendarMember(request.resource.data.calendarId)
        && isWellFormedEvent(request.resource.data);
    }

    match /reminders/{reminderId} {
      allow read: if isRegistered();
    }

    // FR-7: リリース時に CI (Admin SDK) が書き込む最新バージョン情報。
    // クライアントからの書き込みは許可しない（読み取り専用）。
    match /meta/release {
      allow read: if isRegistered();
    }

    // FR-7: 更新履歴（Issue #96）。リリースごとに CI (Admin SDK) が
    // releases/{version} を書き込む。クライアントは設定画面の更新履歴で読むだけ。
    match /releases/{version} {
      allow read: if isRegistered();
    }

    match /users/{uid}/devices/{token} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
